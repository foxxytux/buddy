{
	"compilerOptions": {
		"target": "ES2022",
		"module": "Node16",
		"lib": ["ES2022"],
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"inlineSources": true,
		"inlineSourceMap": false,
		"moduleResolution": "Node16",
		"resolveJsonModule": true,
		"allowImportingTsExtensions": false,
		"experimentalDecorators": true,
		"emitDecoratorMetadata": true,
		"useDefineForClassFields": false,
		"types": ["node"],
		"paths": {
			"*": ["./*"],
			"@foxxytux/buddy-ai": ["./packages/ai/src/index.ts"],
			"@mariozechner/pi-ai": ["./packages/ai/src/index.ts"],
			"@foxxytux/buddy-ai/oauth": ["./packages/ai/src/oauth.ts"],
			"@mariozechner/pi-ai/oauth": ["./packages/ai/src/oauth.ts"],
			"@foxxytux/buddy-ai/*": ["./packages/ai/src/*.ts", "./packages/ai/src/providers/*.ts"],
			"@mariozechner/pi-ai/*": ["./packages/ai/src/*.ts", "./packages/ai/src/providers/*.ts"],
			"@foxxytux/buddy-ai/dist/*": ["./packages/ai/src/*"],
			"@mariozechner/pi-ai/dist/*": ["./packages/ai/src/*"],
			"@foxxytux/buddy-agent-core": ["./packages/agent/src/index.ts"],
			"@mariozechner/pi-agent-core": ["./packages/agent/src/index.ts"],
			"@foxxytux/buddy-agent-core/*": ["./packages/agent/src/*"],
			"@mariozechner/pi-agent-core/*": ["./packages/agent/src/*"],
			"@foxxytux/buddy-coding-agent": ["./packages/coding-agent/src/index.ts"],
			"@mariozechner/pi-coding-agent": ["./packages/coding-agent/src/index.ts"],
			"@foxxytux/buddy-coding-agent/hooks": ["./packages/coding-agent/src/core/hooks/index.ts"],
			"@foxxytux/buddy-coding-agent/*": ["./packages/coding-agent/src/*"],
			"@mariozechner/pi-coding-agent/*": ["./packages/coding-agent/src/*"],
			"@foxxytux/buddy-mom": ["./packages/mom/src/index.ts"],
			"@mariozechner/pi-mom": ["./packages/mom/src/index.ts"],
			"@foxxytux/buddy-mom/*": ["./packages/mom/src/*"],
			"@mariozechner/pi-mom/*": ["./packages/mom/src/*"],
			"@foxxytux/buddy-pods": ["./packages/pods/src/index.ts"],
			"@mariozechner/pi-pods": ["./packages/pods/src/index.ts"],
			"@foxxytux/buddy-pods/*": ["./packages/pods/src/*"],
			"@mariozechner/pi-pods/*": ["./packages/pods/src/*"],
			"@foxxytux/buddy-tui": ["./packages/tui/src/index.ts"],
			"@mariozechner/pi-tui": ["./packages/tui/src/index.ts"],
			"@foxxytux/buddy-tui/*": ["./packages/tui/src/*"],
			"@mariozechner/pi-tui/*": ["./packages/tui/src/*"],
			"typebox": ["./node_modules/typebox"],
			"typebox/*": ["./node_modules/typebox/*"]
		}
	}
}
