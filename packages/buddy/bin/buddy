#!/usr/bin/env node
// Lightweight wrapper that invokes the installed buddy-coding-agent CLI.
// The metapackage depends on the runtime packages; this script resolves and runs
// the coding-agent CLI entrypoint from the installed dependency. If that fails
// it falls back to running the runtime via npx (auto-fetch).
const { spawn } = require('child_process');

function findCli() {
  const fs = require('fs');
  const path = require('path');

  const candidates = new Set();
  const addCandidate = (...parts) => {
    candidates.add(path.join(...parts));
  };

  const roots = [];
  let dir = __dirname;
  for (let i = 0; i < 6; i++) {
    roots.push(dir);
    const parent = path.dirname(dir);
    if (parent === dir) break;
    dir = parent;
  }
  roots.push(process.cwd());

  for (const root of roots) {
    addCandidate(root, '@foxxytux', 'buddy-coding-agent', 'dist', 'cli.js');
    addCandidate(root, 'node_modules', '@foxxytux', 'buddy-coding-agent', 'dist', 'cli.js');
    addCandidate(root, 'packages', 'coding-agent', 'dist', 'cli.js');
  }

  for (const candidate of candidates) {
    try {
      if (fs.existsSync(candidate)) {
        return candidate;
      }
    } catch {
      // ignore
    }
  }

  return null;
}

const cli = findCli();
if (cli) {
  console.error('[buddy] resolved cli:', cli);
  const child = spawn(process.execPath, [cli, ...process.argv.slice(2)], { stdio: 'inherit' });
  child.on('exit', (code) => process.exit(code));
  return;
}

// Fallback: try running via npx to auto-install/execute the runtime package.
// Run npx from a neutral working directory (os.tmpdir()) to avoid resolving a local
// workspace package that may name-collide with the scoped package and cause recursion.
const os = require('os');
const path = require('path');
const npxArgs = ['--yes', '@foxxytux/buddy-coding-agent', ...process.argv.slice(2)];

// Sanitize PATH to avoid local project node_modules/.bin entries (prevents recursion)
const env = Object.assign({}, process.env);
if (env.PATH) {
  env.PATH = env.PATH.split(path.delimiter).filter(p => !p.includes('node_modules' + path.sep + '.bin')).join(path.delimiter);
}

console.error('[buddy] falling back to npx with args:', npxArgs.join(' '));
console.error('[buddy] npx cwd:', os.tmpdir());
console.error('[buddy] filtered PATH:', env.PATH);

const npx = spawn('npx', npxArgs, { stdio: 'inherit', cwd: os.tmpdir(), env });
npx.on('exit', (code) => process.exit(code));

npx.on('error', (err) => {
  console.error('Buddy CLI runtime not found and npx fallback failed.');
  console.error('Install the metapackage: npm i -g @foxxytux/buddy');
  console.error('Or install the runtime packages: npm i -g @foxxytux/buddy-coding-agent @foxxytux/buddy-ai @foxxytux/buddy-tui @foxxytux/buddy-agent-core');
  console.error('Error from npx:', err && err.message ? err.message : err);
  process.exit(1);
});

module.exports = {};
