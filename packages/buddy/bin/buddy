#!/usr/bin/env bash
# Simple wrapper to execute the packaged buddy-test.sh
set -euo pipefail
SCRIPT_DIR=$(cd "$(dirname "$0")/.." >/dev/null 2>&1 && pwd)
BUDDY_SH="$SCRIPT_DIR/buddy-test.sh"
if [ ! -x "$BUDDY_SH" ]; then
  # try to set executable
  chmod +x "$BUDDY_SH" 2>/dev/null || true
fi
if [ -x "$BUDDY_SH" ]; then
  exec "$BUDDY_SH" "$@"
else
  echo "Error: buddy-test.sh not found in package." >&2
  exit 1
fi
