#!/usr/bin/env node
// Node wrapper to run the packaged runner.js which attempts multiple execution strategies
const { join, dirname } = require('path');
const fs = require('fs');

// Resolve real path of this script
let source = process.argv[1];
try {
  source = fs.realpathSync(source);
} catch (e) {
  // ignore
}
const scriptDir = dirname(source);
const runner = join(scriptDir, '..', 'runner.js');
if (fs.existsSync(runner)) {
  const child = require('child_process').spawn(process.execPath, [runner, ...process.argv.slice(2)], { stdio: 'inherit' });
  child.on('exit', (code) => process.exit(code));
} else {
  console.error('Internal error: runner.js not found in package.');
  process.exit(1);
}
