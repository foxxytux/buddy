#!/usr/bin/env node
// Lightweight wrapper that invokes the installed buddy-coding-agent CLI.
// The metapackage depends on the runtime packages; this script resolves and runs
// the coding-agent CLI entrypoint from the installed dependency.
const { spawn } = require('child_process');

function findCli() {
  try {
    return require.resolve('@foxxytux/buddy-coding-agent/dist/cli.js');
  } catch (e) {
    // not installed or not resolvable
  }
  try {
    // Fallback: try resolving package main and locate dist/cli.js relative to it
    const pkgMain = require.resolve('@foxxytux/buddy-coding-agent');
    const path = require('path');
    const pkgDir = path.dirname(pkgMain);
    const candidate = path.join(pkgDir, 'dist', 'cli.js');
    return candidate;
  } catch (e) {
    // give up
  }
  return null;
}

const cli = findCli();
if (!cli) {
  console.error('Buddy CLI runtime not found.');
  console.error('Install the metapackage: npm i -g @foxxytux/buddy');
  console.error('Or install the runtime packages: npm i -g @foxxytux/buddy-coding-agent @foxxytux/buddy-ai @foxxytux/buddy-tui @foxxytux/buddy-agent-core');
  process.exit(1);
}

const child = spawn(process.execPath, [cli, ...process.argv.slice(2)], { stdio: 'inherit' });
child.on('exit', (code) => process.exit(code));
module.exports = {};
